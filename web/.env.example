# Public site URL (canonical, OG, security scans).
NEXT_PUBLIC_SITE_URL=https://rename.bimcheck-consulting.com

# Optional temporary private-access gate.
# Leave empty for a public SaaS (recommended for launch).
DOC_RENAME_ACCESS_PASSWORD=

# Stripe Payment Links — SaaS V1 prices: Team 19€, Cabinet 49€, Pilot 49€
# (see STRIPE_SETUP.md / docs/product/PRICING_AUDIT.md).
# Empty → CTAs fall back to /pilot (no dead buttons).
#
# PRODUCTION = LIVE ONLY. Vercel production always forces mode=live and
# rejects buy.stripe.com/test_* links. Do not put test links on Production.
# OAuth/org is optional for revenue (manual fulfillment under 1 business day).
NEXT_PUBLIC_PAID_CHECKOUT_ENABLED=false
# test = Preview/local QA only. live = real money. Production ignores "test".
NEXT_PUBLIC_STRIPE_MODE=live
NEXT_PUBLIC_STRIPE_LINK_TEAM_EUR=
NEXT_PUBLIC_STRIPE_LINK_CABINET_EUR=
NEXT_PUBLIC_STRIPE_LINK_PILOT=

# Stripe webhook — server-only. Configure in Vercel/Convex secret stores only.
# STRIPE_WEBHOOK_SECRET=
# Public Stripe object IDs used as a server-side entitlement allowlist.
STRIPE_PAYMENT_LINK_TEAM_ID=plink_...
STRIPE_PAYMENT_LINK_CABINET_ID=plink_...
STRIPE_PAYMENT_LINK_PILOT_ID=plink_...
# Server-side mode must be exactly "live" in Production (real money).
# "test" is only for Preview webhook experiments — never on Production.
# STRIPE_MODE=live
# Optional currency-specific checkout links:
# NEXT_PUBLIC_STRIPE_LINK_TEAM_CHF=
# NEXT_PUBLIC_STRIPE_LINK_TEAM_USD=
# NEXT_PUBLIC_STRIPE_LINK_CABINET_CHF=
# NEXT_PUBLIC_STRIPE_LINK_CABINET_USD=
# NEXT_PUBLIC_STRIPE_LINK_PILOT_CHF=
# NEXT_PUBLIC_STRIPE_LINK_PILOT_USD=
# Legacy aliases still accepted by pricing.ts:
# NEXT_PUBLIC_STRIPE_LINK_TEAM=
# NEXT_PUBLIC_STRIPE_LINK_PRO=
# NEXT_PUBLIC_STRIPE_LINK_CABINET=

# Deploy-level plan for public instance: free | team | cabinet | pro (legacy=team).
NEXT_PUBLIC_DOC_RENAME_PLAN=free

# Convex (auth + convention sync). Required for /login and cloud save.
# Keep false until at least one OAuth provider is configured and smoke-tested.
NEXT_PUBLIC_AUTH_ENABLED=false
# Separate fail-closed switch. Enable only after organisation membership,
# entitlement revocation and production account journeys are fully tested.
NEXT_PUBLIC_PAID_ACCOUNTS_ENABLED=false
# CONVEX_DEPLOYMENT=
# NEXT_PUBLIC_CONVEX_URL=
# NEXT_PUBLIC_CONVEX_SITE_URL=
# Server-only shared secret for the public pilot-request ingestion route.
# Configure in Vercel and Convex secret stores; never prefix with NEXT_PUBLIC_.
# PILOT_REQUEST_INGEST_SECRET=
# Server-side paid feature gate. Keep false until entitlement ordering,
# revocation, organisation quotas and invitation verification are complete.
PAID_SAAS_ENABLED=false

# Optional multi-industry kill-switch (default: multi-métier ON).
# NEXT_PUBLIC_BIM_ONLY=false

# Sentry (disabled until DSN set)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0

# PostHog (disabled until key set)
NEXT_PUBLIC_TELEMETRY_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
